# ─────────────────────────────────────────────────────────────────
#  ShieldKit — Environment Configuration
#  Copy this file:  cp .env.example .env  then fill in your values.
#  All keys are optional; the server starts in mock mode without any.
# ─────────────────────────────────────────────────────────────────

# ── Mode ─────────────────────────────────────────────────────────
# mock  = demo data, no real tools required  (default)
# live  = run actual scanners (Syft, Grype, Trivy, ZAP, Prowler…)
SHIELDKIT_MODE=mock

# ── Server ───────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── AI Chatbot (SOCPilot) ─────────────────────────────────────────
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-…           # Your Anthropic API key
AI_MODEL=claude-sonnet-4-20250514

# ── Secrets Manager ──────────────────────────────────────────────
# Options: local_encrypted | hashicorp_vault | aws_secrets | azure_keyvault | gcp_secret
SECRETS_PROVIDER=local_encrypted
SHIELDKIT_MASTER_KEY=         # Set a strong random key for AES-256 encryption (auto-generated if empty)

# ── Database Backend ─────────────────────────────────────────────
# Options: local | motherduck | s3_sync | postgres
DB_BACKEND=local
DUCKDB_PATH=data/shieldkit.duckdb

# MotherDuck (cloud DuckDB — shareable across CI runners):
# MOTHERDUCK_TOKEN=md_…
# MOTHERDUCK_DB=shieldkit

# S3 sync (sync local DuckDB to/from S3 for CI persistence):
# DB_S3_BUCKET=my-security-bucket
# DB_S3_KEY=shieldkit/shieldkit.duckdb
# DB_S3_REGION=us-east-1

# PostgreSQL (for multi-instance shared state):
# DB_POSTGRES_URL=postgresql://user:pass@host:5432/shieldkit

# ── Cloud Credentials (for cloud posture scans) ───────────────────
# AWS
# AWS_PROFILE=default
# AWS_REGION=us-east-1

# Azure
# AZURE_SUBSCRIPTION_ID=…
# AZURE_TENANT_ID=…

# GCP
# GCP_PROJECT_ID=my-project

# ── OWASP ZAP DAST ───────────────────────────────────────────────
ZAP_USE_DOCKER=true
ZAP_DOCKER_IMAGE=ghcr.io/zaproxy/zaproxy:stable
# ZAP_HOST=zap                # If using --profile tools docker-compose service
# ZAP_PORT=8080
# ZAP_API_KEY=

# ── Tool Binary Paths (defaults work if tools are in PATH) ─────────
# SYFT_BIN=syft
# GRYPE_BIN=grype
# TRIVY_BIN=trivy
# NUCLEI_BIN=nuclei
# PROWLER_BIN=prowler
# CHECKOV_BIN=checkov
# SCOUTSUITE_BIN=scout

# ── Log Ingestion ────────────────────────────────────────────────
LOG_RETENTION_DAYS=90
